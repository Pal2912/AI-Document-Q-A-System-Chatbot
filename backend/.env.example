# ============================================
# DATABASE CONFIGURATION
# ============================================
# Format: postgresql://<user>:<password>@<host>:<port>/<database_name>
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/rag_chatbot_db

# ============================================
# JWT AUTHENTICATION
# ============================================
# Generate a strong secret with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace_this_with_a_long_random_secret_string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ============================================
# GOOGLE GEMINI API
# ============================================
# Get your key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ============================================
# EMBEDDINGS (runs locally, no API key needed)
# ============================================
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ============================================
# FILE STORAGE
# ============================================
UPLOAD_DIR=storage/uploaded_pdfs
VECTOR_STORE_DIR=storage/vector_store
MAX_UPLOAD_SIZE_MB=20

# ============================================
# APP / CORS
# ============================================
APP_ENV=development
FRONTEND_URL=http://localhost:5173
